# Copy this file to .env and update the values

# PostgreSQL connection string (with PostGIS)
DATABASE_URL=postgresql://postgres:password@localhost:5432/smartrecycling

# Redis connection
REDIS_URL=redis://localhost:6379/0

# App secret (change in production!)
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Set to "false" when a real database is connected
USE_MOCK_DATA=true

# Model weight paths (relative to backend/ directory)
BATTERY_MODEL_PATH=../ai_models/battery_health/weights/
SOLAR_MODEL_PATH=../ai_models/solar_degradation/weights/
